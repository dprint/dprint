---
layout: layouts/base.njk
isDocumentation: true
---

<div class="docs">
  <aside class="doc-sidebar">
    <details class="doc-nav" open>
      <summary class="doc-nav-summary">Documentation menu</summary>
      {% include "partials/doc-menu.njk" %}
    </details>
  </aside>
  <main class="doc-main doc-content">
    {% set eyebrowText = eyebrow %}
    {% if not eyebrowText %}{% set eyebrowText = "plugins" if "/plugin" in url else "guide" %}{% endif %}
    <div class="eyebrow">// {{ eyebrowText }}</div>
    {{ content | safe }}
  </main>
</div>
