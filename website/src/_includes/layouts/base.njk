<!DOCTYPE html>
<html lang="en">
  <head>
    <script async src="/scripts.js"></script>
    <meta charset="utf-8" />
    <title>{% if title %}{{ title }} - dprint - Code Formatter{% else %}dprint - Code Formatter{% endif %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#1e1e1e" />
    <meta name="description" content="{{ description }}" />
    <meta name="author" content="Dprint Code Formatting" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@dprintfmt" />
    <meta name="twitter:title" content="{{ title }}" />
    <meta name="twitter:description" content="{{ description }}" />
    {% if robots == false %}<meta name="robots" content="noindex">{% endif %}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <nav class="site-nav">
      <div class="nav-inner">
        <a class="brand" href="/">dprint</a>
        <div class="nav-links">
          <a href="/overview"{% if isDocumentation %} class="active"{% endif %}>Overview</a>
          <a href="/playground">Playground</a>
          <a href="/sponsor"{% if url == "/sponsor/" %} class="active"{% endif %}>Sponsor</a>
          <a class="gh-button" href="https://github.com/dprint/dprint" rel="noopener noreferrer">GitHub <span>↗</span></a>
        </div>
      </div>
    </nav>

    <main class="site-main">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">dprint</div>
        <div class="footer-links">
          <a href="/">Home</a>
          <a href="/contact">Contact</a>
          <a href="https://twitter.com/dprintfmt">Twitter</a>
          <a href="https://github.com/dprint">GitHub</a>
        </div>
        <div class="footer-tag">A code formatting platform · Rust + Wasm</div>
      </div>
    </footer>
  </body>
</html>
